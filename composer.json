{
    "name": "oihana/php-controllers",
    "type": "library",
    "description": "The Oihana PHP Controllers library",
    "keywords": [
        "php",
        "controllers",
        "http",
        "slim",
        "twig",
        "psr-7",
        "rest"
    ],
    "homepage": "https://github.com/BcommeBois/oihana-php-controllers",
    "license": [
        "MPL-2.0"
    ],
    "authors": [
        {
            "name": "Marc Alcaraz",
            "email": "marc@ooop.fr",
            "homepage": "https://www.ooop.fr",
            "role": "Project Founder, Lead Developer."
        }
    ],
    "support": {
        "email": "marc@ooop.fr"
    },
    "autoload": {
        "psr-4": {
            "oihana\\controllers\\": "src/oihana/controllers"
        },
        "files": [
            "src/oihana/controllers/helpers/applyContentHeaders.php",
            "src/oihana/controllers/helpers/computeETag.php",
            "src/oihana/controllers/helpers/etagMatches.php",
            "src/oihana/controllers/helpers/filterLanguages.php",
            "src/oihana/controllers/helpers/getBodyParam.php",
            "src/oihana/controllers/helpers/getBodyParams.php",
            "src/oihana/controllers/helpers/getController.php",
            "src/oihana/controllers/helpers/getParam.php",
            "src/oihana/controllers/helpers/getParamArray.php",
            "src/oihana/controllers/helpers/getParamBool.php",
            "src/oihana/controllers/helpers/getParamFloat.php",
            "src/oihana/controllers/helpers/getParamFloatRange.php",
            "src/oihana/controllers/helpers/getParamI18n.php",
            "src/oihana/controllers/helpers/getParamInt.php",
            "src/oihana/controllers/helpers/getParamIntRange.php",
            "src/oihana/controllers/helpers/getParamNumberRange.php",
            "src/oihana/controllers/helpers/getParamString.php",
            "src/oihana/controllers/helpers/getQueryParam.php",
            "src/oihana/controllers/helpers/parseRangeHeader.php",
            "src/oihana/controllers/helpers/translate.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\": "tests"
        }
    },
    "require": {
        "php": ">=8.4",
        "ext-imagick": "*",
        "oihana/php-core": "dev-main",
        "oihana/php-enums": "dev-main",
        "oihana/php-exceptions": "dev-main",
        "oihana/php-files": "dev-main",
        "oihana/php-logging": "dev-main",
        "oihana/php-models": "dev-main",
        "oihana/php-reflect": "dev-main",
        "oihana/php-schema": "dev-main",
        "oihana/php-traits": "dev-main",
        "php-di/php-di": "^7.0",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "slim/twig-view": "^3.4",
        "slim/csrf": "^1.5",
        "slim/http-cache": "^1.2",
        "twig/twig": "^3.21",
        "somnambulist/validation": "^1.12",
        "psr/container": "^2.0",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/http-server-middleware": "^1.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12",
        "nunomaduro/collision": "^8.8",
        "phpdocumentor/shim": "^3.8"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "./vendor/bin/phpunit",
        "doc": "rm -rf docs && mkdir docs && cp -r assets docs/assets && ./vendor/bin/phpdoc -c phpdoc.xml -v",
        "coverage": "XDEBUG_MODE=coverage ./vendor/bin/phpunit --coverage-text --coverage-clover build/coverage/clover.xml --coverage-html build/coverage/html",
        "coverage:md": [
            "@coverage",
            "php tools/clover-to-markdown.php build/coverage/clover.xml build/coverage/COVERAGE.md"
        ],
        "post-install-cmd": [],
        "post-update-cmd": []
    },
    "config": {
        "allow-plugins": {
            "phpdocumentor/shim": true
        }
    }
}
